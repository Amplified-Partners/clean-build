{
  "name": "amplified-docs",
  "version": "0.1.0",
  "private": true,
  "description": "Amplified Partners repo — markdownlint toolchain enforcing Google Markdown style guide for AI-interoperable docs",
  "scripts": {
    "lint:md": "markdownlint '**/*.md' --ignore node_modules --ignore 'Claude Chats'",
