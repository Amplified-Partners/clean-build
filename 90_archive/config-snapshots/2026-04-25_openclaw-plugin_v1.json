{
  "id": "whatsapp-official",
  "name": "Official WhatsApp API (imBee)",
  "version": "0.1.12",
  "description": "Connect OpenClaw to WhatsApp through the imBee managed Cloud API channel.",
  "author": "imBee Limited",
  "capabilities": ["channel"],
  "channels": ["whatsapp-official"],
  "channelId": "whatsapp-official",
  "setupWizard": true,
  "entryPoint": "./index.ts",
  "configSchema": {
    "title": "Official WhatsApp API Channel Config",
    "type": "object",
    "properties": {
      "routingBaseUrl": {
        "type": "string",
        "description": "Routing server base URL, e.g. http://localhost:28080",
        "default": "http://localhost:28080"
      },
      "instanceId": {
        "type": "string",
        "description": "Unique OpenClaw instance identifier"
      },
      "apiKey": {
        "type": "string",
        "description": "Bearer token returned by POST /api/v1/pair/request (store via OpenClaw secrets when available)"
      },
      "allowFrom": {
        "type": "array",
        "items": { "type": "string" },
        "description": "E.164 allowlist for inbound WhatsApp senders"
      },
      "defaultTo": {
        "type": "string",
        "description": "Optional default outbound peer (E.164)"
      },
      "dmPolicy": {
        "type": "string",
        "enum": ["open", "pairing", "allowlist", "disabled"],
        "default": "open"
      },
      "groupPolicy": {
        "type": "string",
        "enum": ["open", "disabled", "allowlist"],
        "default": "disabled"
      }
    },
    "required": []
  }
}
