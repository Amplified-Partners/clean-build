[Unit]
Description=Docker-User Firewall Rules (AMP-289)
Documentation=https://linear.app/amplifiedpartners/issue/AMP-289
# Must run after iptables/nftables are available but before Docker publishes ports
After=network-pre.target
Before=docker.service
Wants=docker.service

[Service]
Type=oneshot
RemainAfterExit=yes
ExecStart=/opt/amplified/security/docker-user-firewall.sh
ExecReload=/opt/amplified/security/docker-user-firewall.sh

# Run again if Docker restarts (it flushes DOCKER-USER on restart)
ExecStartPost=/bin/sh -c 'echo "DOCKER-USER rules loaded"'

[Install]
WantedBy=multi-user.target

