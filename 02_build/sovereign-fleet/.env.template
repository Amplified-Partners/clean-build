# OpenClaw Sovereign Fleet — Environment Variables
# Copy to .env and fill in your values: cp .env.template .env
# Authored by Devon | 2026-05-02 | devin-701075c43e444229aa32f993bf60b36a

# ── Tailscale (VPN mesh) ──────────────────────────────────────────
# Generate at: https://login.tailscale.com/admin/settings/keys
TS_AUTHKEY=

# ── LiteLLM (Model Router) ───────────────────────────────────────
# Points to the LiteLLM proxy on Beast (already running).
LITELLM_BASE_URL=http://litellm:4000
LITELLM_API_KEY=

# ── Policy Selection ────────────────────────────────────────────
# Which Cedar policy file to load. Default: prod.cedar (strict gates).
# Set to dev.cedar for local development (relaxed approval gates).
POLICY_FILE=prod.cedar

# ── Model Overrides (LiteLLM model identifiers) ──────────────────
# These map the MODEL_OVERRIDE env to actual LiteLLM model names.
LITELLM_MODEL_KIMI=openai/moonshot-v1-auto
LITELLM_MODEL_OPUS=anthropic/claude-sonnet-4-20250514  # config key is claude_opus (legacy name)
LITELLM_MODEL_DEEPSEEK=deepseek/deepseek-chat

# ── Workspace Mounts ─────────────────────────────────────────────
# Absolute paths on the host for each entity's workspace.
# Default: relative to this directory (../Entity_Kimmy, etc.)
# WORKSPACE_KIMMY=/opt/openclaw/workspaces/kimmy
# WORKSPACE_ALPHA=/opt/openclaw/workspaces/alpha
# WORKSPACE_CHARLIE=/opt/openclaw/workspaces/charlie

# ── Traefik Ports ────────────────────────────────────────────────
# Adjust if these conflict with existing services on the host.
TRAEFIK_HTTP_PORT=8180
TRAEFIK_HTTPS_PORT=8443
TRAEFIK_DASHBOARD_PORT=8181

# ── Logging ──────────────────────────────────────────────────────
LOG_LEVEL=INFO
