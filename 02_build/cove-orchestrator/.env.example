# Cove Orchestrator — Environment Variables
# Copy to .env and fill in your values: cp .env.example .env

# ─── PostgreSQL ──────────────────────────────────────────────────────
POSTGRES_PASSWORD=cove_dev_2026
POSTGRES_DSN=postgresql://cove:cove_dev_2026@localhost:5432/cove

# ─── Temporal ────────────────────────────────────────────────────────
TEMPORAL_ADDRESS=localhost:7233

# ─── LiteLLM (Model Routing) ────────────────────────────────────────
LITELLM_API_BASE=http://localhost:4000
LITELLM_API_KEY=
LITELLM_MASTER_KEY=sk-litellm-master-key-change-me
LITELLM_DATABASE_URL=postgresql://cove:cove_dev_2026@localhost:5432/cove

# ─── Anthropic (Claude) ─────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ─── DeepSeek (Cheap Tier) ──────────────────────────────────────────
DEEPSEEK_API_KEY=

# ─── OpenAI (Fallback) ──────────────────────────────────────────────
OPENAI_API_KEY=

# ─── Telegram Bot ────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ─── GitHub ──────────────────────────────────────────────────────────
GITHUB_TOKEN=

# ─── Langfuse (Observability) ───────────────────────────────────────
LANGFUSE_HOST=http://localhost:3000
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_NEXTAUTH_SECRET=changeme-in-production
LANGFUSE_SALT=changeme-in-production

# ─── Visual Polish Gate (AMP-73) ───────────────────────────────────
# Shared secret used by gated repos' GHAs to authenticate to polish-gate-api.
# Generate with: openssl rand -hex 32
COVE_POLISH_GATE_TOKEN=
# Composite-score threshold below which the gate fails the PR.
POLISH_GATE_THRESHOLD=0.65
# Default rubric and rules paths inside the worker / api containers.
POLISH_GATE_RUBRIC_PATH=/opt/visual-polish-system/principles/references/rubric.json
POLISH_GATE_RULES_PATH=/opt/visual-polish-system/principles/rules/core.rules.json
# Optional: directory of few-shot reference screenshots (AMP-VPS-002).
POLISH_GATE_REFERENCES_DIR=
# Host port the polish-gate-api listens on. Beast firewall must allow ingress.
COVE_POLISH_GATE_PORT=8090
