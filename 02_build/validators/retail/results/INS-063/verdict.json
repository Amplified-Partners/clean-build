         \n                        \n                    </tr>\n                    \n                    <tr class=\"govuk-table__row\">\n                        <th scope=\"row\" class=\"govuk-table__cell\">Postcode</th>\n                        \n                            \n                            <td class=\"govuk-table__cell\"></td>\n                            \n                        \n                            \n                            <td class=\"govuk-table__cell\">BH99 9ZZ</td>\n                            \n                        \n                    </tr>\n                    \n                    <tr class=\"govuk-table__row\">\n                        <th scope=\"row\" class=\"govuk-table__cell\">Multiple address indicator</th>\n                        \n                            \n                            <td class=\"govuk-table__cell\">N</td>\n                            \n                        \n                            \n                            <td class=\"govuk-table__cell\">Y</td>\n                            \n                        \n                    </tr>\n                    \n                    <tr class=\"govuk-table__row\">\n                        <th scope=\"row\" class=\"govuk-table__cell\">Price paid</th>\n                        \n                            \n                            <td class=\"govuk-table__cell\"></td>\n                            \n                        \n                            \n                            <td class=\"govuk-table__cell\">59100</td>\n                            \n                        \n                    </tr>\n                    \n                    <tr class=\"govuk-table__row\">\n                        <th scope=\"row\" class=\"govuk-table__cell\">Proprietor name</th>\n                        \n                            \n                            <td class=\"govuk-table__cell\">Sopley View Freehold Limited</td>\n                            \n                        \n                            \n                            <td class=\"govuk-table__cell\">Downton Bloor Housing Association Limited</td>\n                            \n                        \n                    </tr>\n                    \n                    <tr class=\"govuk-table__row\">\n                        <th scope=\"row\" class=\"govuk-table__cell\">Company registration number</th>\n                        \n                            \n                            <td class=\"govuk-table__cell\">9999999</td>\n                            \n                        \n                            \n                            <td class=\"govuk-table__cell\">99999</td>\n                            \n                        \n                    </tr>\n                    \n                    <tr class=\"govuk-table__row\">\n                        <th scope=\"row\" class=\"govuk-table__cell\">Proprietorship category</th>\n                        \n                            \n                            <td class=\"govuk-table__cell\">Limited Company or Public Limited Company</td>\n                            \n                        \n                            \n                            <td class=\"govuk-table__cell\">Community Benefit Society (Company)</td>\n                            \n                        \n                    </tr>\n                    \n                    <tr class=\"govuk-table__row\">\n                        <th scope=\"row\" class=\"govuk-table__cell\">Proprietor address</th>\n                        \n                            \n                            <td class=\"govuk-table__cell\">\n                                \n                                    21 Norfolk Grange<br>\n                                \n                                    Bournemouth<br>\n                                \n                                    BH56 8UT<br>\n                                \n                            </td>\n                            \n                        \n                            \n                            <td class=\"govuk-table__cell\">\n                                \n                                    Holborne House<br>\n                                \n                                    Tuckton<br>\n                                \n                                    BH56 3ML<br>\n                                \n                            </td>\n                            \n                        \n                    </tr>\n                    \n                    <tr class=\"govuk-table__row\">\n                        <th scope=\"row\" class=\"govuk-table__cell\">Date proprietor added</th>\n                        \n                            \n                            <td class=\"govuk-table__cell\">24/09/2012</td>\n                            \n                        \n                            \n                            <td class=\"govuk-table__cell\">25/01/2017</td>\n                            \n                        \n                    </tr>\n                    \n                    <tr class=\"govuk-table__row\">\n                        <th scope=\"row\" class=\"govuk-table__cell\">Additional proprietor indicator </th>\n                        \n                            \n                            <td class=\"govuk-table__cell\">N</td>\n                            \n                        \n                            \n                            <td class=\"govuk-table__cell\">N</td>\n                            \n                        \n                    </tr>\n                    \n                    <tr class=\"govuk-table__row\">\n                        <th scope=\"row\" class=\"govuk-table__cell\">Change indicator (change only update)</th>\n                        \n                            \n                            <td class=\"govuk-table__cell\">A</td>\n                            \n                        \n                            \n                            <td class=\"govuk-table__cell\">D</td>\n                            \n                        \n                    </tr>\n                    \n                    <tr class=\"govuk-table__row\">\n                        <th scope=\"row\" class=\"govuk-table__cell\">Change date</th>\n                        \n                            \n                            <td class=\"govuk-table__cell\">16/09/2019 </td>\n                            \n                        \n                            \n                            <td class=\"govuk-table__cell\">16/09/2019</td>\n                            \n                        \n                    </tr>\n                    \n                </tbody>\n            </table>\n            <br>\n            <br>\n            <br>\n            <h2 id=\"access\" class=\"govuk-heading-l\">Access the dataset</h2>\n            \n                <p class=\"govuk-body\">\n                    You will need to <a class=\"govuk-link\" href=\"/registration\">create an account</a>\n                    or <a class=\"govuk-link\" href=\"/sign-in\">sign in</a> to your account, and agree\n                    to the <a class=\"govuk-link\" href=\"/datasets/ccod/licence/view\">data licence</a>.\n                </p>\n            \n            <h3 class=\"govuk-heading-m\">Download the data</h3>\n            <p class=\"govuk-body\">\n                The dataset is updated on the second working day of the month and contains data for the previous month.\n                For example, files published in April show data from March.\n                The data includes CSV files.\n                You can download the:\n            </p>\n            <ul class=\"govuk-list govuk-list--bullet\">\n                <li>\n                    complete file - this is a complete file of the current data and contains all of the\n                    changes that happened during the month\n                </li>\n                <li>\n                    change only file - this includes data that has changed since the previous month's release\n                </li>\n            </ul>\n            <p class=\"govuk-body\">\n                Data between March 2014 and September 2017 was published quarterly and had a different structure. We do\n                not have any data files before March 2014.\n                <a class=\"govuk-link\" href=\"/datasets/ccod/historical/tech-spec\">\n                    Read the technical specification for these files</a>.\n            </p>\n            <h3 class=\"govuk-heading-m\">Access the data with an API</h3>\n            <p class=\"govuk-body\">\n                You will get an API key when you've:\n            </p>\n            <ul class=\"govuk-list govuk-list--bullet\">\n                <li>created your account</li>\n                <li>signed in</li>\n                <li>agreed to the data licence</li>\n            </ul>\n            <p class=\"govuk-body\">\n                For more information, read our guides on <a class=\"govuk-link\" href=\"/api-information\">\n                accessing data with the API</a> and <a class=\"govuk-link\" href=\"/api-documentation\">\n                API technical details</a>.\n            </p>\n            <h3 class=\"govuk-heading-m\">How the data can be used</h3>\n            <p class=\"govuk-body\">\n                This data has a <a class=\"govuk-link\" href=\"/datasets/ccod/licence/view\">licence</a> which explains how you can use it.\n                If you\u2019re not sure that you can use the data in the way you need,\n                email <a class=\"govuk-link\" href=\"/cdn-cgi/l/email-protection#87e6e3e3f5e2f4f4a9eae6e9e6e0e2eae2e9f3c7f5e8fee6ebeae6eeeba9e4e8ea\" title=\"This link will open your default email application\"><span class=\"__cf_email__\" data-cfemail=\"c4a5a0a0b6a1b7b7eaa9a5aaa5a3a1a9a1aab084b6abbda5a8a9a5ada8eaa7aba9\">[email&#160;protected]</span></a> to check.\n            </p>\n            <p class=\"govuk-body\">\n                The licence sets out the conditions for the re-use of data (in this case, addresses) which contain third party intellectual\n                property rights. Property addresses contained within the UK companies that own property in England and Wales data are\n                processed against Ordnance Survey\u2019s AddressBase Premium product, which incorporates Royal Mail\u2019s PAF\u00ae database (Address Data).\n            </p>\n            \n                <a class=\"govuk-button\" href=\"/registration\">Create account</a>\n                <a class=\"govuk-link\" href=\"/sign-in\"\n                    style=\"padding-left: 30px; margin-top: 8px; position: absolute; font-size: 22px\">Sign in</a>\n            \n            <br>\n            <br>\n            <br>\n            <h2 id=\"contact\" class=\"govuk-heading-l\">\n                Contact us\n            </h2>\n            <p>\n                Contact us if you need help with the dataset or have any questions:\n            </p>\n            <h3 class=\"govuk-heading-s\">\n                Telephone\n            </h3>\n            <ul class=\"govuk-list\">\n                <li>Telephone: 0300 006 0478</li>\n                <li>Monday to Friday, 9am to 5pm</li>\n            </ul>\n            <p class=\"govuk-body\">\n                <a class=\"govuk-link\" href=\"https://www.gov.uk/call-charges\">Find out about call charges</a>\n            </p>\n\n            <h3 class=\"govuk-heading-s\">\n                Email\n            </h3>\n            <ul class=\"govuk-list\">\n                <li><a title=\"This link will open your default email application\" class=\"govuk-link\" href=\"/cdn-cgi/l/email-protection#177376637639647265617e747264577a767e7b397b7679736572707e6463656e3970786139627c\"><span class=\"__cf_email__\" data-cfemail=\"05616471642b766077736c6660764568646c692b69646b617760626c7671777c2b626a732b706e\">[email&#160;protected]</span></a></li>\n                <li>We aim to respond within 2 working days</li>\n            </ul>\n\n            <h3 class=\"govuk-heading-s\">\n                Address\n            </h3>\n            <p class=\"govuk-body\">\n                Data Services Team\u200b<br>\n                HM Land Registry\u200b<br>\n                Rosebrae Court \u200b<br>\n                Woodside Ferry Approach\u200b<br>\n                Birkenhead\u200b<br>\n                Merseyside\u200b<br>\n                CH41 6DU\n            </p>\n        </div>\n    </div>\n    <script data-cfasync=\"false\" src=\"/cdn-cgi/scripts/5c5dd728/cloudflare-static/email-decode.min.js\"></script><script>\n    (function () {\n        scrollFunc = function (e) {\n            var footer = document.querySelector('footer.govuk-footer');\n            var backToTopFixed = document.getElementById('back-to-top-fixed');\n            var backToTopBottom = document.getElementById('back-to-top-bottom');\n            var windowScrollBottom = window.pageYOffset + window.innerHeight;\n\n            // Don't display the back to top link at all if less than 400px into page\n            if (window.pageYOffset < 400) {\n                backToTopFixed.style.display = 'none';\n                backToTopBottom.classList.add('base-bar--hidden');\n            } else {\n                // Hide the scrolling back to top link if we've reached the footer (and hide from screen reader)\n                // Now show the bottom static back to top link\n                if (windowScrollBottom > document.body.clientHeight - footer.offsetHeight) {\n                    backToTopFixed.style.display = 'none';\n\n                    backToTopBottom.classList.remove('base-bar--hidden');\n                    backToTopBottom.setAttribute('aria-hidden', false);\n                // Show the scrolling link if we're at least 400px into the screen and haven't reached footer\n                // Hide the static bottom link (and hide from screen reader)\n                } else {\n                    backToTopFixed.style.display = 'block';\n\n                    backToTopBottom.classList.add('base-bar--hidden');\n                    backToTopBottom.setAttribute('aria-hidden', true);\n                }\n            }\n        };\n\n        setLinkFunc = function (e) {\n            var svg = ''.concat(\n                '<svg role=\"presentation\" focusable=\"false\" class=\"back-to-top__icon\" xmlns=\"http://www.w3.org/2000/svg\" nwidth=\"13\" height=\"17\" viewBox=\"0 0 13 17\">',\n                '     <path fill=\"currentColor\" d=\"M6.5 0L0 6.5 1.4 8l4-4v12.7h2V4l4.3 4L13 6.4z\"></path>',\n                '</svg>'\n            );\n            var backToTopLinks = [\n                document.getElementById(\"back-to-top-link-scroll\"),\n                document.getElementById(\"back-to-top-link-bottom\")\n            ];\n\n            // Always reset to original <svg> which will remove text etc\n            backToTopLinks.forEach(function(link) {\n                link.innerHTML = svg;\n            });\n\n            // Check if contents list in dom and ensure it's visible (e.g. selected tab)\n            var contents = document.getElementById(\"contents\");\n            is_visible = contents && contents.offsetWidth > 0 && contents.offsetHeight > 0;\n\n            // Set back to top link text/href depending on whether 'contents' is visible\n            var text = is_visible ? 'Contents' : 'Back to top';\n            var href = is_visible ? '#contents' : '#top';\n\n            backToTopLinks.forEach(function(link) {\n                link.appendChild(document.createTextNode(text));\n                link.href = href;\n            });\n        };\n        \n        // Set event listeners \n        window.addEventListener('scroll', scrollFunc);\n        window.addEventListener('load', setLinkFunc);\n\n        // If there are tabs on the screen (e.g. homepage) then need to ensure code gets called on 'hashchange'\n        if (document.querySelector('[data-module=tabs]')) {\n            window.addEventListener('hashchange', function (e) {\n                setLinkFunc(e);\n                scrollFunc(e);\n            });\n        }\n    })();\n</script>\n\n<div class=\"base-bar-wrapper\">\n    <div id=\"back-to-top-fixed\" class=\"base-bar base-bar--fixed\">\n        <div class=\"govuk-width-container\">\n            <a class=\"govuk-link govuk-link--no-visited-state\" id=\"back-to-top-link-scroll\" href=\"#top\">\n                <noscript>\n                    <svg role=\"presentation\" focusable=\"false\" class=\"back-to-top__icon\" xmlns=\"http://www.w3.org/2000/svg\" nwidth=\"13\" height=\"17\" viewBox=\"0 0 13 17\">\n                        <path fill=\"currentColor\" d=\"M6.5 0L0 6.5 1.4 8l4-4v12.7h2V4l4.3 4L13 6.4z\"></path>\n                    </svg>\n                    Back to top\n                </noscript>\n            </a>\n        </div>\n    </div>\n\n    <div id=\"back-to-top-bottom\" class=\"base-bar base-bar--bottom\">\n        <a class=\"govuk-link govuk-link--no-visited-state\" id=\"back-to-top-link-bottom\" href=\"#top\">\n            <noscript>\n                <svg role=\"presentation\" focusable=\"false\" class=\"back-to-top__icon\" xmlns=\"http://www.w3.org/2000/svg\" nwidth=\"13\" height=\"17\" viewBox=\"0 0 13 17\">\n                    <path fill=\"currentColor\" d=\"M6.5 0L0 6.5 1.4 8l4-4v12.7h2V4l4.3 4L13 6.4z\"></path>\n                </svg>\n                Back to top\n            </noscript>\n        </a>\n    </div>\n</div>\n</div>\n</main>\n    </div>\n\n    <footer class=\"govuk-footer \" role=\"contentinfo\">\n  <div class=\"govuk-width-container \">\n    <div class=\"govuk-footer__meta\">\n      <div class=\"govuk-footer__meta-item govuk-footer__meta-item--grow\">\n        <h2 class=\"govuk-visually-hidden\">Support links</h2>\n        <ul class=\"govuk-footer__inline-list\"