          "cachedResultName": "GPT-4.1-MINI"
        },
        "messages": {
          "values": [
            {
              "content": "=You are a lead scoring assistant for a B2B SaaS-focused AI Automation Agency.\n\nYour job is to evaluate incoming leads and assign a score from 1 to 5 based on the following criteria:\n\n- **Revenue** (1 point): If Monthly revenue is greater than $10,000 give it 1 point, if less than $10,000 give it 0 point\n- **Employees** (1 point): If the company has more than 5 employees give it 1 point, If less than 5 employees give it 0 point\n- **Budget** (2 points): If the stated budget is over $3,000 give it 2 points, if less than $3,000 give it 0 points\n- **Website Score** (1 point): Awarded separately based on presence of relevant keywords (e.g., AI, automation, SaaS).\n\n\n### Scoring Outcome:\n- **Reject** if total score is 1–3  \n- **Accept** if total score is 4–5\n\nUse the lead details above to calculate the score (0–5), and determine whether the lead should be accepted or rejected.",
              "role": "system"
            },
            {
              "content": "=Here are the lead's details;\n\nBudget: {{ $('On form submission').item.json.Budget }}\nRevenue per Month: {{ $('On form submission').item.json['Revenue Per Month'] }}\nWebsite: {{ $json.message.content.website_score }}\nNumber of Employees: {{ $('On form submission').item.json['Number of employees'] }}"
            },
            {
              "content": "=Please output the data in JSON format, using the following structure:\n\n{\n  \"score\": 5,\n  \"decision\": \"Accept\",\n  \"reasoning\": \"Revenue > $10k (1), employees > 5 (1), budget > $3k (1), website keywords matched (2)\"\n}",
              "role": "assistant"
            }
          ]
        },
        "jsonOutput": true,
        "options": {}
      },
