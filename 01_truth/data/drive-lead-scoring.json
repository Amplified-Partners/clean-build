        "messages": {
          "values": [
            {
              "content": "=You are a lead qualification expert at an AI Automation Agency. Your job is to analyze website content and determine if the company fits our target industry profile.\n\nAward **1 point** if the website is a service based business. Award 0 points if it's outside of the services industry, such as SAAS, products, e-commerce, etc. Here's some examples of service businesses (it's not an exhaustive list):\n- Plumbing\n- Photography\n- Marketing\n- Video editing\n- Landscaping\n\n\nReturn a JSON object like this:\nExample\n{\n  \"matched_keywords\": [\"A\", \"B\", \"C\"],\n  \"website_score\": 1 or 0,\n  \"reasoning\": \"Explain briefly why the score was given.\"\n}\n",
              "role": "system"
            },
            {
              "content": "=Here is the website content:\n\n{{ $json.body }}"
            },
            {
              "content": "=Please output the data in JSON format, using the following structure:\n\n{\n  \"matched_keywords\": [\"A\", \"B\", \"C\"],\n  \"website_score\": 2 or 0,\n  \"reasoning\": \"Explain briefly why the score was given.\"\n}",
              "role": "assistant"
            }
          ]
        },
        "jsonOutput": true,
        "options": {}
      },
